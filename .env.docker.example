# Docker deployment environment variables
#
# Usage:
#   cp .env.docker.example .env
#   docker compose up --build -d

# App
NODE_ENV="production"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-strong-secret"

# Database (inside docker-compose)
# You can override if you use an external database.
DOCKER_DATABASE_URL="postgresql://postgres:postgres@db:5432/lasu_eng_2001?schema=public"

# Seed (initial SUPER_ADMIN account)
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD="replace-me"

# Email (optional; used for verification + notifications)
# SMTP_URL="smtp://user:pass@smtp.example.com:587"
# MAIL_FROM="LASU Engineering 2001 <no-reply@example.com>"

# Payments
PAYMENTS_CURRENCY="NGN"
ANNUAL_DUES_AMOUNT_MINOR="1000000"

# Stripe (optional; required to enable checkout)
# STRIPE_PUBLIC_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
DOCKER_DATABASE_URL="postgresql://postgres:postgres@db:5432/lasu_eng_2001?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-strong-secret"

SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD="replace-me"

# Optional
# SMTP_URL="smtp://user:pass@smtp.example.com:587"
# MAIL_FROM="LASU Engineering 2001 <no-reply@example.com>"

# Optional Stripe keys
# STRIPE_PUBLIC_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

PAYMENTS_CURRENCY="NGN"
ANNUAL_DUES_AMOUNT_MINOR="1000000"
