# Primary DB connection string used by app/runtime and Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lasu_eng_2001?schema=public"

# Optional override for Prisma CLI only. If omitted, Prisma uses DATABASE_URL.
# PRISMA_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lasu_eng_2001?schema=public"

# App
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-strong-secret"

# Seed (initial SUPER_ADMIN account)
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD="replace-me"

# Email (optional; used for verification + notifications)
# SMTP_URL="smtp://user:pass@smtp.example.com:587"
# MAIL_FROM="LASU Engineering 2001 <no-reply@example.com>"

# Payments (Stripe)
# STRIPE_PUBLIC_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
PAYMENTS_CURRENCY="NGN"
ANNUAL_DUES_AMOUNT_MINOR="1000000"
